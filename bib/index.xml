      <description>&lt;style&gt;
/* 页面全局控制 */
body {
  max-width: 920px;
  margin: 4rem auto 1rem auto; /* 顶部增加留白，不紧贴导航 */
  padding: 0 24px;
}
h1 {
  color: #2c5aa0;
  font-size: 1.6rem;
  margin-bottom: 20px;
  font-weight: 500;
}
/* Bib代码容器：英文Times New Roman，学术标准字体 */
.bib-box {
  background: #f7f9fc;
  border: 1px solid #e2e8f0;
  border-radius: 10px;
  padding: 20px;
  /* 英文优先Times New Roman，兜底等宽字体保证对齐 */
  font-family: &#34;Times New Roman&#34;, &#34;Consolas&#34;, &#34;Menlo&#34;, monospace;
  font-size: 0.82rem;
  line-height: 1.6;
  white-space: pre-wrap;
  position: relative;
  color: #111;
}
/* 复制按钮样式 */
.copy-btn {
  position: absolute;
  top: 12px;
  right: 12px;
  padding: 5px 12px;
  background: #2c5aa0;
  color: white;
  border: none;
  border-radius: 6px;
  cursor: pointer;
  font-size: 0.75rem;
  font-family: Arial, sans-serif;
}
.copy-btn:hover {
  background: #1d4880;
}
/* 复制成功提示 */
.tip-text {
  color: #208c42;
  font-size: 0.8rem;
  margin-top: 12px;
  display: none;
  font-family: &#34;Microsoft YaHei&#34;, sans-serif;
}
.download-link {
  display: inline-block;
  margin-top: 12px; /* 加大与提示文字间距 */
  color: #2c5aa0;
  text-decoration: none;
  font-size: 0.85rem;
  font-family: &#34;Microsoft YaHei&#34;, sans-serif;
}
.download-link:hover {
  text-decoration: underline;
}
&lt;/style&gt;
&lt;div class=&#34;bib-box&#34; id=&#34;bibContent&#34;&gt;
@article{meng2026joint,
  title={Joint Classification of Hyperspectral and LiDAR Data Based on Dynamic Sparse-Dense Transformer and Mamba},
  author={Meng, Zhe and Yang, Zixin and Zhao, Feng},
  journal={IEEE Journal of Selected Topics in Applied Earth Observations and Remote Sensing},
  volume={19},
  pages={11445--11461},
  year={2026},
  publisher={IEEE}
}
  &lt;button class=&#34;copy-btn&#34; onclick=&#34;copyBib()&#34;&gt;复制全部BibTeX&lt;/button&gt;
&lt;/div&gt;
&lt;p class=&#34;tip-text&#34; id=&#34;copyTip&#34;&gt;✅ 复制成功，可直接粘贴到Zotero / LaTeX&lt;/p&gt;
&lt;a class=&#34;download-link&#34; href=&#34;https://www.zhemeng.site/bib/2026-01.bib&#34; target=&#34;_blank&#34; rel=&#34;noopener noreferrer&#34; download&gt;📥 下载标准 .bib 文件&lt;/a&gt;
&lt;!-- 底部空白区域 --&gt;
&lt;div style=&#34;height: 110px;&#34;&gt;&lt;/div&gt;
&lt;script&gt;
function copyBib() {
  // 用 #bibText 单独存内容，不混入按钮文字
  const text = document.getElementById(&#39;bibText&#39;).innerText.trim();
  navigator.clipboard.writeText(text)
    .then(() =&gt; {
      const tip = document.getElementById(&#39;copyTip&#39;);
      tip.style.display = &#39;block&#39;;
      setTimeout(() =&gt; tip.style.display = &#39;none&#39;, 3000);
    })
    .catch(() =&gt; {
      // 如果 Clipboard API 失败，弹出提示
      alert(&#39;复制失败，请手动复制&#39;);
    });
}
&lt;/script&gt;
</description>
